{
  "manifest_version": 3,
  "name": "ProfSis3 - Extensão para Aulas de Hoje",
  "version": "2.6.2",
  "description": "Exibe as aulas do dia do ProfSis em um card de agenda na Sala do Futuro e permite extrair alunos direto para o banco.",
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://saladofuturoprofessor.educacao.sp.gov.br/*",
    "https://saladofuturo.educacao.sp.gov.br/*",
    "https://*.educacao.sp.gov.br/*",
    "*://localhost/*",
    "*://127.0.0.1/*",
    "https://*.firebaseapp.com/*",
    "https://*.profsis3.com/*",
    "https://*.web.app/*",
    "https://*.github.io/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://localhost/*", "*://127.0.0.1/*", "https://*.firebaseapp.com/*", "https://*.profsis3.com/*", "https://*.web.app/*", "https://*.github.io/*"],
      "js": ["content_profsis.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://saladofuturoprofessor.educacao.sp.gov.br/*",
        "https://saladofuturo.educacao.sp.gov.br/*"
      ],
      "js": ["content_sed.js"],
      "run_at": "document_idle"
    }
  ]
}